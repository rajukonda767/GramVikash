# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_NUMBER=+1xxxxxxxxxx  # Twilio phone number (e.g., +12025551234)

# Recipient phone numbers (comma-separated)
TWILIO_RECIPIENT_PHONES=+91xxxxxxxxxx,+91xxxxxxxxxx,+91xxxxxxxxxx,+91xxxxxxxxxx

# Flask Configuration
PORT=5000

# Optional: Set to True for development only
DEBUG=False
